#!/usr/bin/env python3
"""lapdog — a loyal little CLI stopwatch.

Controls:
  space   start / pause
  l       record lap
  r       reset
  q       quit
"""

import signal
import select
import sys
import termios
import time
import tty


# ---------- formatting ----------

def fmt(seconds: float) -> str:
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = seconds % 60
    return f"{h:02d}:{m:02d}:{s:06.3f}"


def fmt_hms(seconds: float) -> str:
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = int(seconds % 60)
    return f"{h:02d}:{m:02d}:{s:02d}"


def fmt_ms(seconds: float) -> str:
    ms = int((seconds - int(seconds)) * 1000)
    return f".{ms:03d}"


